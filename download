                borderRadius: "50%",
                background: m.photoColor,
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                color: "#fff",
                fontWeight: 700,
                fontFamily: "'Fredoka', sans-serif",
                fontSize: 18,
                flexShrink: 0,
              }}
            >
              {initials(m.name)}
            </div>
            <div style={{ flex: 1, minWidth: 0 }}>
              <div style={{ fontWeight: 600, fontSize: 15, color: "#2D1B2E" }}>
                {m.name}
              </div>
              <div
                style={{
                  fontSize: 13,
                  color: "#8a7a8c",
                  whiteSpace: "nowrap",
                  overflow: "hidden",
                  textOverflow: "ellipsis",
                }}
              >
                {last ? last.text : "Say hi!"}
              </div>
            </div>
          </button>
        );
      })}
    </div>
  );
}

// ---------- App Root ----------

export default function DatingApp() {
  const [tab, setTab] = useState("discover");
  const [matches, setMatches] = useState([]);
  const [messagesByMatch, setMessagesByMatch] = useState({});
  const [activeChat, setActiveChat] = useState(null);

  const handleMatch = (profile) => {
    setMatches((prev) => {
      if (prev.find((p) => p.id === profile.id)) return prev;
      return [profile, ...prev];
    });
    setMessagesByMatch((prev) => ({ ...prev, [profile.id]: prev[profile.id] || [] }));
  };

  const handleSendMessage = (matchId, text) => {
    setMessagesByMatch((prev) => {
      const existing = prev[matchId] || [];
      const updated = [...existing, { from: "me", text }];
      return { ...prev, [matchId]: updated };
    });

    // Simulate a reply for demo purposes
    setTimeout(() => {
      const reply = CANNED_REPLIES[Math.floor(Math.random() * CANNED_REPLIES.length)];
      setMessagesByMatch((prev) => {
        const existing = prev[matchId] || [];
        return { ...prev, [matchId]: [...existing, { from: "them", text: reply }] };
      });
    }, 900 + Math.random() * 900);
  };

  const openChat = (profile) => setActiveChat(profile);
  const closeChat = () => setActiveChat(null);

  return (
    <div
      style={{
        maxWidth: 420,
        margin: "0 auto",
        height: "100vh",
        maxHeight: 800,
        background: "#FFF8F3",
        display: "flex",
        flexDirection: "column",
        fontFamily: "'Inter', sans-serif",
        borderRadius: 28,
        overflow: "hidden",
        boxShadow: "0 0 0 1px rgba(45,27,46,0.06)",
        position: "relative",
      }}
    >
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Inter:wght@400;500;600&display=swap"
      />

      {activeChat ? (
        <ChatScreen
          profile={activeChat}
          messages={messagesByMatch[activeChat.id] || []}
          onSend={handleSendMessage}
          onBack={closeChat}
        />
      ) : (
        <>
          <div style={{ flex: 1, position: "relative", overflow: "hidden" }}>
            {tab === "discover" && <DiscoverScreen onMatch={handleMatch} />}
            {tab === "matches" && (
              <MatchesScreen matches={matches} onOpenChat={openChat} />
            )}
            {tab === "chats" && (
              <ChatsListScreen
                matches={matches}
                messagesByMatch={messagesByMatch}
                onOpenChat={openChat}
              />
            )}
          </div>
          <BottomNav active={tab} onChange={setTab} matchCount={matches.length} />
        </>
      )}
    </div>
  );
}
