}

// ---------- Discover Screen ----------

function DiscoverScreen({ onMatch }) {
  const [deck, setDeck] = useState(PROFILES);
  const [matchPopup, setMatchPopup] = useState(null);

  const handleSwipe = (direction, profile) => {
    setDeck((prev) => prev.filter((p) => p.id !== profile.id));
    if (direction === "like") {
      // Random chance to "match" for demo purposes, biased toward yes for fun
      const isMatch = Math.random() > 0.35;
      if (isMatch) {
        onMatch(profile);
        setMatchPopup(profile);
      }
    }
  };

  const buttonAction = (direction) => {
    if (deck.length === 0) return;
    const top = deck[0];
    handleSwipe(direction, top);
  };

  return (
    <div style={{ display: "flex", flexDirection: "column", height: "100%" }}>
      <div
        style={{
          position: "relative",
          flex: 1,
          margin: "16px 20px 0",
        }}
      >
        {deck.length === 0 ? (
          <div
            style={{
              position: "absolute",
              inset: 0,
              display: "flex",
              flexDirection: "column",
              alignItems: "center",
              justifyContent: "center",
              textAlign: "center",
              color: "#2D1B2E",
              padding: 32,
            }}
          >
            <Sparkles size={40} color="#FFD93D" style={{ marginBottom: 12 }} />
            <h2
              style={{
                fontFamily: "'Fredoka', sans-serif",
                fontSize: 22,
                margin: "0 0 8px",
              }}
            >
              You're all caught up
            </h2>
            <p style={{ fontSize: 14, color: "#6b5a6c", margin: 0 }}>
              Check back later for more people nearby.
            </p>
          </div>
        ) : (
          deck
            .slice(0, 3)
            .map((profile, i) => (
              <SwipeCard
                key={profile.id}
                profile={profile}
                isTop={i === 0}
                stackIndex={i}
                onSwipe={handleSwipe}
