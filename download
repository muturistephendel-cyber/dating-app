// ---------- Swipe Card ----------

function SwipeCard({ profile, onSwipe, isTop, stackIndex }) {
  const cardRef = useRef(null);
  const [drag, setDrag] = useState({ x: 0, y: 0, active: false });
  const startRef = useRef({ x: 0, y: 0 });

  const handlePointerDown = (e) => {
    if (!isTop) return;
    const point = e.touches ? e.touches[0] : e;
    startRef.current = { x: point.clientX, y: point.clientY };
    setDrag((d) => ({ ...d, active: true }));
  };

  const handlePointerMove = useCallback(
    (e) => {
      if (!drag.active || !isTop) return;
      const point = e.touches ? e.touches[0] : e;
      const dx = point.clientX - startRef.current.x;
      const dy = point.clientY - startRef.current.y;
      setDrag({ x: dx, y: dy, active: true });
    },
    [drag.active, isTop]
  );

  const handlePointerUp = useCallback(() => {
    if (!isTop) return;
    const threshold = 110;
    if (drag.x > threshold) {
      onSwipe("like", profile);
    } else if (drag.x < -threshold) {
      onSwipe("nope", profile);
    } else {
      setDrag({ x: 0, y: 0, active: false });
    }
  }, [drag.x, isTop, onSwipe, profile]);

  React.useEffect(() => {
    if (!drag.active) return;
    window.addEventListener("mousemove", handlePointerMove);
    window.addEventListener("mouseup", handlePointerUp);
    window.addEventListener("touchmove", handlePointerMove);
    window.addEventListener("touchend", handlePointerUp);
    return () => {
      window.removeEventListener("mousemove", handlePointerMove);
      window.removeEventListener("mouseup", handlePointerUp);
      window.removeEventListener("touchmove", handlePointerMove);
      window.removeEventListener("touchend", handlePointerUp);
    };
  }, [drag.active, handlePointerMove, handlePointerUp]);

  const rotation = drag.x / 20;
  const likeOpacity = Math.min(Math.max(drag.x / 100, 0), 1);
  const nopeOpacity = Math.min(Math.max(-drag.x / 100, 0), 1);

  const offsetScale = isTop ? 1 : 1 - stackIndex * 0.04;
  const offsetY = isTop ? 0 : stackIndex * 10;

  return (
    <div
      ref={cardRef}
      onMouseDown={handlePointerDown}
      onTouchStart={handlePointerDown}
      style={{
        position: "absolute",
        inset: 0,
        borderRadius: 24,
        overflow: "hidden",
        cursor: isTop ? (drag.active ? "grabbing" : "grab") : "default",
        transform: `translate(${drag.x}px, ${drag.y + offsetY}px) rotate(${rotation}deg) scale(${offsetScale})`,
        transition: drag.active ? "none" : "transform 0.35s cubic-bezier(.2,.8,.2,1)",
        touchAction: "none",
        userSelect: "none",
        boxShadow: isTop
          ? "0 20px 50px -12px rgba(45,27,46,0.35)"
          : "0 8px 24px -8px rgba(45,27,46,0.2)",
        zIndex: isTop ? 10 : 10 - stackIndex,
      }}
    >
      <div
        style={{
          position: "absolute",
          inset: 0,
          background: `linear-gradient(160deg, ${profile.photoColor}dd, ${profile.photoColor}88)`,
        }}
      />
      <div
        style={{
          position: "absolute",
          inset: 0,
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
        }}
      >
        <div
          style={{
            width: 140,
            height: 140,
            borderRadius: "50%",
            background: "rgba(255,255,255,0.25)",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            fontSize: 56,
            fontWeight: 700,
            color: "#fff",
            fontFamily: "'Fredoka', sans-serif",
          }}
        >
          {initials(profile.name)}
        </div>
      </div>

      {/* LIKE stamp */}
      <div
        style={{
          position: "absolute",
          top: 32,
          left: 24,
          padding: "8px 18px",
          border: "4px solid #4ECDC4",
          borderRadius: 10,
          color: "#4ECDC4",
          fontFamily: "'Fredoka', sans-serif",
          fontWeight: 700,
          fontSize: 30,
          letterSpacing: 2,
          transform: "rotate(-18deg)",
          opacity: likeOpacity,
          background: "rgba(255,255,255,0.85)",
        }}
      >
        LIKE
      </div>

      {/* NOPE stamp */}
      <div
        style={{
          position: "absolute",
          top: 32,
          right: 24,
          padding: "8px 18px",
          border: "4px solid #FF6B6B",
          borderRadius: 10,
          color: "#FF6B6B",
          fontFamily: "'Fredoka', sans-serif",
          fontWeight: 700,
          fontSize: 30,
          letterSpacing: 2,
          transform: "rotate(18deg)",
          opacity: nopeOpacity,
          background: "rgba(255,255,255,0.85)",
        }}
      >
        NOPE
      </div>

      {/* Info panel */}
      <div
        style={{
          position: "absolute",
          bottom: 0,
          left: 0,
          right: 0,
          padding: "70px 22px 22px",
          background:
            "linear-gradient(to top, rgba(45,27,46,0.92), rgba(45,27,46,0.55) 60%, transparent)",
